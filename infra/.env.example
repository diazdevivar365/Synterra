# Forgentic (Synterra) — secret reference map
# All secrets live in Infisical project "forgentic-prod" (or "forgentic-dev").
# This file is a reference ONLY — never commit real values.
# deploy-synterra.sh exports these at runtime via `infisical export`.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://app.forgentic.app

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forgentic:<password>@192.168.10.50:5432/synterra
POSTGRES_USER=forgentic
POSTGRES_PASSWORD=<generate-with: openssl rand -base64 32>
POSTGRES_DB=synterra
B2_BUCKET_NAME=forgentic-db-backups

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:<password>@192.168.10.51:6379/0
REDIS_PASSWORD=<generate-with: openssl rand -base64 32>

# ── Auth (better-auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=<generate-with: openssl rand -base64 32>
BETTER_AUTH_URL=https://app.forgentic.app

# WorkOS (gated to Scale plan — see W1-3)
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=

# ── Aquila data plane ─────────────────────────────────────────────────────────
AQUILA_BASE_URL=http://192.168.10.42:8000
AQUILA_API_KEY=<aquila-org-api-key>
AQUILA_CONTRACT_VERSION=2026-04

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<key>

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<key>
STRIPE_WEBHOOK_SECRET=whsec_<key>
STRIPE_PUBLISHABLE_KEY=pk_live_<key>

# ── Billing (Lago) ────────────────────────────────────────────────────────────
LAGO_API_URL=http://192.168.10.53:3000
LAGO_API_KEY=<lago-api-key>
LAGO_POSTGRES_USER=lago
LAGO_POSTGRES_PASSWORD=<generate>
LAGO_POSTGRES_DB=lago
LAGO_SECRET_KEY_BASE=<generate-with: openssl rand -hex 64>
LAGO_RSA_PRIVATE_KEY=<base64-encoded RSA private key>
LAGO_ENCRYPTION_PRIMARY_KEY=<generate>
LAGO_ENCRYPTION_DETERMINISTIC_KEY=<generate>
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=<generate>
LAGO_FRONT_URL=http://metering.lan

# ── Cloudflare ────────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=<from CF dashboard → Zero Trust → Tunnels>

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.10.54:4318
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<generate>
GRAFANA_ROOT_URL=http://192.168.10.54:3001

# ── Status page (Cachet) ──────────────────────────────────────────────────────
CACHET_APP_KEY=<generate-with: openssl rand -base64 32>
CACHET_APP_URL=http://status.forgentic.app
CACHET_DB_USER=cachet
CACHET_DB_PASSWORD=<generate>
CACHET_DB_NAME=cachet

# ── SMTP (shared — Grafana + Cachet + Resend fallback) ───────────────────────
SMTP_HOST=smtp.resend.com
SMTP_USER=resend
SMTP_PASSWORD=<resend-api-key>
SMTP_FROM=noreply@forgentic.app

# ── Infisical bootstrap (lives in /etc/forgentic/deploy.secret, NOT Infisical) ──
# INFISICAL_CLIENT_ID=<machine-identity-client-id>
# INFISICAL_CLIENT_SECRET=<machine-identity-secret>
# INFISICAL_PROJECT_ID=<infisical-project-id>
