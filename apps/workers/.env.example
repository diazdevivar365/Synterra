# apps/workers — environment variable reference
# All secrets live in Infisical project "forgentic-prod" (or "forgentic-dev").
# This file is a reference ONLY — never commit real values.
# Copy to .env.local and fill in your dev values.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forgentic:<password>@localhost:5432/synterra

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Health sidecar ────────────────────────────────────────────────────────────
HEALTH_PORT=3002

# ── Aquila data plane ─────────────────────────────────────────────────────────
AQUILA_BASE_URL=http://192.168.10.42:8000
AQUILA_API_KEY=<aquila-org-api-key>
AQUILA_CONTRACT_VERSION=2026-04

# ── W2-3 — Bootstrap worker (anon-org provisioning) ──────────────────────────
AQUILA_ANON_API_KEY=placeholder-anon-key
AQUILA_ANON_ORG_SLUG=synterra-anon
AQUILA_ANON_ORG_ID=placeholder-uuid

# ── Observability ─────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
