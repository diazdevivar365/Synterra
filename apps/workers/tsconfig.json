{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "@synterra/tsconfig/node",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "outDir": "./dist",
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "vitest.config.ts", "tsup.config.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
