{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "@synterra/tsconfig/next",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@synterra/shared": ["../../packages/shared/src/index.ts"],
      "drizzle-orm": ["./node_modules/@synterra/db/node_modules/drizzle-orm/index.d.ts"],
      "drizzle-orm/*": ["./node_modules/@synterra/db/node_modules/drizzle-orm/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules", ".next", "dist", "coverage"]
}
