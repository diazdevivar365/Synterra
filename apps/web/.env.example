# apps/web — environment variable reference
# All secrets live in Infisical project "forgentic-prod" (or "forgentic-dev").
# This file is a reference ONLY — never commit real values.
# Copy to .env.local and fill in your dev values.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forgentic:<password>@localhost:5432/synterra

# ── Auth (better-auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=<generate-with: openssl rand -base64 32>
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_DATABASE_URL=postgresql://forgentic:<password>@localhost:5432/synterra

# ── Social auth (optional) ────────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_<key>

# ── WorkOS (Scale plan — W1-3) ────────────────────────────────────────────────
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_WEBHOOK_SECRET=

# ── Aquila data plane ─────────────────────────────────────────────────────────
AQUILA_BASE_URL=http://192.168.10.42:8000
AQUILA_API_KEY=<aquila-org-api-key>
AQUILA_CONTRACT_VERSION=2026-04

# ── W2-3 — URL-first onboarding ───────────────────────────────────────────────
CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key
IP_HASH_SALT=random-32-char-string

# ── Redis (rate limiting / job queue) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Observability ─────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
