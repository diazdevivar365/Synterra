# EditorConfig — https://editorconfig.org
# Forgentic (codename: Synterra) monorepo.
# Aligns editor behaviour with Prettier + .gitattributes.

root = true

[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 2
insert_final_newline     = true
trim_trailing_whitespace = true

[*.md]
# Two trailing spaces can be a hard line break in Markdown.
trim_trailing_whitespace = false
max_line_length          = 120

[{*.yml,*.yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
