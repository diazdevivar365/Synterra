# pnpm configuration
# https://pnpm.io/npmrc

# ─── Engine enforcement ────────────────────────────────────────────────────────
# Fail hard if Node/pnpm versions don't satisfy package.json#engines.
# Defense against sessions/devs that enter with wrong Node.
engine-strict=true

# ─── Peer dependencies ─────────────────────────────────────────────────────────
# Refuse to install if peer deps are unsatisfied. Surfaces real conflicts early.
strict-peer-dependencies=true

# Don't silently install peers — explicit control over every dep.
auto-install-peers=false

# ─── Hoisting / linking ────────────────────────────────────────────────────────
# Isolated node_modules — each workspace gets only what it declares.
# Prevents accidental imports of transitive deps ("phantom dependencies").
node-linker=isolated

# Shared lockfile at workspace root.
shared-workspace-lockfile=true

# ─── Install hardening ─────────────────────────────────────────────────────────
# Reject downgrade installs; prefer honoring existing lockfile.
prefer-frozen-lockfile=true

# ─── Resolution ────────────────────────────────────────────────────────────────
# Canonical npm registry.
registry=https://registry.npmjs.org/

# Keep caret-ranged saves by default (not pinned). Apps can override per-entry.
save-prefix=^
