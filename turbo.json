{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".nvmrc", ".node-version", ".npmrc", "pnpm-workspace.yaml", "packages/tsconfig/*.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "globalPassThroughEnv": ["NPM_TOKEN", "GITHUB_TOKEN", "TURBO_TOKEN", "TURBO_TEAM"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local", ".env.production", "!.env*.example"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"],
      "passThroughEnv": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "REDIS_URL",
        "AQUILA_BASE_URL",
        "AQUILA_API_KEY",
        "AQUILA_PROVISIONER_SECRET",
        "AQUILA_ENCRYPT_KEY",
        "NEXT_PUBLIC_APP_URL",
        "RESEND_API_KEY",
        "STRIPE_PUBLISHABLE_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "WORKOS_API_KEY",
        "WORKOS_CLIENT_ID",
        "CLOUDFLARE_TUNNEL_TOKEN"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "interruptible": true
    },
    "lint": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", ".eslintrc*", "eslint.config.*", "../../eslint.config.*"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["**/*.tsbuildinfo"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "tsconfig.*.json"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.*", "vitest.workspace.*"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
