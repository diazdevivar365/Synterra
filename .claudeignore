# Claude Code — archivos excluidos de lectura/búsqueda
# Evita blowup de contexto en sesiones de trabajo

# Dependencias (cientos de MB, nunca útiles para Claude)
node_modules/
.pnpm-store/

# Builds y outputs generados
.next/
dist/
build/
out/

# Lock files (miles de líneas, no aportan contexto)
pnpm-lock.yaml
package-lock.yaml

# Git worktrees (copias completas del repo — borrarlas al cerrar cada branch)
.worktrees/

# Turbo cache
.turbo/

# Test artifacts
coverage/
playwright-report/
test-results/
