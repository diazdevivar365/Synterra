{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "@synterra/tsconfig/node",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts", "drizzle.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "coverage", "drizzle", "migrations"]
}
